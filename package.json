    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.6",
    "@primeicons/angular": "^8.0.0-rc.2",
    "@primeuix/themes": "^3.0.0-rc.1",
    "express": "^5.1.0",
    "primeng": "^22.0.0-rc.1",
